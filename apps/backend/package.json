{
  "name": "@my-agent-team/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Team Runtime HTTP Server — L5 Backend",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./app": "./dist/app.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run --cwd ../.. build --filter=@my-agent-team/backend^... && bun run src/main.ts",
    "lint": "biome check . && eslint .",
    "format": "biome check --write .",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "db:generate:backend": "drizzle-kit generate --config drizzle.backend.config.ts",
    "db:migrate:backend": "bun run src/main.ts",
    "db:check:backend": "drizzle-kit check --config drizzle.backend.config.ts"
  },
  "dependencies": {
    "@my-agent-team/adapter-mcp": "workspace:*",
    "@my-agent-team/ai": "workspace:*",
    "@my-agent-team/api-contract": "workspace:*",
    "@my-agent-team/config": "workspace:*",
    "@my-agent-team/conversation": "workspace:*",
    "@my-agent-team/core": "workspace:*",
    "@my-agent-team/framework": "workspace:*",
    "@my-agent-team/harness": "workspace:*",
    "@my-agent-team/loop": "workspace:*",
    "@my-agent-team/message": "workspace:*",
    "@my-agent-team/plugin-conversation-context": "workspace:*",
    "@my-agent-team/plugin-fs-memory": "workspace:*",
    "@my-agent-team/plugin-goal": "workspace:*",
    "@my-agent-team/plugin-identity": "workspace:*",
    "@my-agent-team/plugin-pet": "workspace:*",
    "@my-agent-team/plugin-progressive-skill": "workspace:*",
    "@my-agent-team/plugin-todo": "workspace:*",
    "@my-agent-team/runtime-observability": "workspace:*",
    "@my-agent-team/tools-common": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "elysia": "^1.0.0",
    "handlebars": "^4.7.9",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@my-agent-team/test-helpers": "workspace:*"
  }
}
