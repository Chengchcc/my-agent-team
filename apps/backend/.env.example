# Backend — required (one of ANTHROPIC_API_KEY or ANTHROPIC_AUTH_TOKEN)
ANTHROPIC_AUTH_TOKEN=            # <-- YOUR API KEY
# ANTHROPIC_API_KEY=sk-ant-...   # alternative: standard Anthropic key
BACKEND_AUTH_TOKEN=dev-token     # <-- pick a random string, share with apps/web

# Backend — optional (defaults shown)
# ANTHROPIC_BASE_URL=https://api.anthropic.com   # API proxy / alternative endpoint
# BACKEND_PORT=3000
# BACKEND_HOST=127.0.0.1
# BACKEND_DATA_DIR=./.backend-data
# BACKEND_MAX_CONCURRENT=8
