# BFF → Backend connection (server-side only, never sent to browser)
BACKEND_URL=http://127.0.0.1:3001
BACKEND_AUTH_TOKEN=dev-token

# Session signing (HMAC-SHA256 via crypto.subtle)
SESSION_SECRET=                  # <-- YOU MUST PROVIDE: any random string, e.g. openssl rand -hex 32

# MVP single-user login
MOCK_USER_ID=user-001
MOCK_PASSWORD=admin
