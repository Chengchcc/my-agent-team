{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "50%",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!dist/**",
        "!.next/**",
        "!.turbo/**",
        "!coverage/**",
        "!**/*.tsbuildinfo"
      ]
    },
    "test": {
      "dependsOn": ["^build", "^test"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    }
  }
}
