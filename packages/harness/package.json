{
  "name": "@my-agent-team/harness",
  "version": "0.1.0",
  "description": "File-driven generic agent harness — workspace files define agent behavior",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "biome check . && eslint .",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@my-agent-team/checkpointer-sqlite": "workspace:*",
    "@my-agent-team/core": "workspace:*",
    "@my-agent-team/framework": "workspace:*",
    "@my-agent-team/plugin-fs-memory": "workspace:*",
    "@my-agent-team/plugin-progressive-skill": "workspace:*",
    "@my-agent-team/plugin-task-guard": "workspace:*",
    "@my-agent-team/tools-common": "workspace:*"
  },
  "devDependencies": {}
}
