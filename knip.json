{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "bin/my-agent-daemon.ts",
    "bin/my-agent-cli.ts",
    "examples/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.test.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "ignoreDependencies": [],
  "ignoreBinaries": ["tsc"],
  "ignore": [
    "tests/fixtures/**",
    "src/index.ts",
    "src/domain/agent.ts",
    "src/infrastructure/_sqlite/connection.ts",
    "src/infrastructure/session/sqlite-session-schema.ts",
    "src/infrastructure/session/sqlite-session-store.ts",
    "src/infrastructure/session/sqlite-history-store.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "tags": ["-public", "-internal"],
  "rules": {
    "exports": "error",
    "types": "error",
    "duplicates": "error",
    "files": "error",
    "dependencies": "error",
    "unlisted": "error"
  },
  "bun": true
}
