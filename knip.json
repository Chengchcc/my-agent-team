{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "bin/my-agent-daemon.ts",
    "scripts/**/*.ts",
    "tests/**/*.test.{ts,tsx}",
    "tests/**/*.spec.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "tests/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "ignoreDependencies": ["@types/diff"],
  "ignoreBinaries": ["tsc"],
  "ignore": [
    "tests/fixtures/**"
  ],
  "ignoreExportsUsedInFile": true,
  "tags": ["-public", "-internal"],
  "rules": {
    "exports": "error",
    "types": "error",
    "duplicates": "error",
    "files": "error",
    "dependencies": "error",
    "unlisted": "error"
  },
  "bun": true
}
