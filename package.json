{
  "name": "my-agent",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "my-agent": "bin/my-agent.ts",
    "my-agent-tui": "bin/my-agent-tui"
  },
  "scripts": {
    "tui": "bun run bin/my-agent-tui-dev.ts",
    "agent": "bun run bin/my-agent.ts",
    "tsc": "tsc",
    "build": "tsc",
    "dev": "bun run bin/my-agent-tui-dev.ts",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'bin/**/*.ts'",
    "check:guard": "tsc --noEmit",
    "check:arch": "bun run scripts/check-architecture.ts",
    "check:deadcode": "bun x knip --no-progress --reporter compact",
    "check:all": "tsc --noEmit && bun test && bun run check:arch",
    "baseline:any": "bun run scripts/update-any-baseline.ts",
    "prepare": "cp scripts/git-hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "knip": "^5.0.0",
    "minimatch": "^10.2.5",
    "ts-morph": "^23.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tavily/core": "^0.7.3",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "immer": "^11.1.4",
    "ink": "^5.0.1",
    "js-yaml": "^4.1.1",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "nanoid": "^5.1.9",
    "openai": "^6.34.0",
    "p-limit": "^3.1.0",
    "prismjs": "^1.29.0",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "sqlite-vec": "^0.1.9",
    "string-width": "^8.2.1",
    "zod": "^3.22.4",
    "zustand": "^5.0.12"
  }
}
