{
  "name": "my-agent-team",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "create": "bun run scripts/create-package.ts",
    "predev": "bash scripts/predev.sh",
    "dev": "bash scripts/dev.sh",
    "predev:backend": "bash scripts/predev.sh",
    "dev:backend": "bun run --cwd apps/backend dev",
    "predev:web": "bash scripts/predev.sh",
    "dev:web": "bun run --cwd apps/web dev",
    "predev:turbo": "bash scripts/predev.sh",
    "dev:turbo": "turbo run dev --parallel",
    "format": "biome format --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "ci": "turbo run build --concurrency=1 && turbo run typecheck --concurrency=1 && turbo run test --concurrency=1",
    "prepare": "husky"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@inquirer/prompts": "^8.5.2",
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "typescript-language-server": "^5.3.0"
  },
  "dependencies": {
    "drizzle-zod": "^0.8.3",
    "marked": "^18.0.5",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remend": "^1.3.0"
  }
}
